#!/usr/bin/env bash

set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source_icon="${repo_dir}/crates/zed/resources/app-icon@2x.png"
entitlements="${repo_dir}/crates/zed/resources/zed.entitlements"
cli_bin_dir="${HOME}/.local/bin"

install_app() {
  local app_name="$1"
  local bundle_identifier="$2"
  local build_command="$3"
  local binary_path="$4"
  local runtime_release_channel="$5"
  local build_failure_message="$6"

  local app_dir="${HOME}/Applications/${app_name}.app"
  local contents_dir="${app_dir}/Contents"
  local macos_dir="${contents_dir}/MacOS"
  local resources_dir="${contents_dir}/Resources"
  local iconset_dir="${resources_dir}/${app_name}.iconset"
  local icon_file="${resources_dir}/${app_name}.icns"
  local launcher="${macos_dir}/${app_name}"

  mkdir -p "${macos_dir}" "${resources_dir}" "${iconset_dir}"

  cat > "${contents_dir}/Info.plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>${app_name}</string>
	<key>CFBundleExecutable</key>
	<string>${app_name}</string>
	<key>CFBundleIconFile</key>
	<string>${app_name}</string>
	<key>CFBundleIdentifier</key>
	<string>${bundle_identifier}</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>${app_name}</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>10.15.7</string>
	<key>NSHighResolutionCapable</key>
	<true/>
</dict>
</plist>
EOF

  cat > "${launcher}" <<EOF
#!/bin/zsh

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\${PATH}"

repo_dir="${repo_dir}"
entitlements="${entitlements}"
log_dir="\${HOME}/Library/Logs/SlopZed"
log_file="\${log_dir}/${app_name}.log"
build_state_path="\${log_dir}/${bundle_identifier}.build-state"
binary_path="\${repo_dir}/${binary_path}"
binary_identifier="${bundle_identifier}.zed"

build_if_needed() {
  local current_head
  local dirty_status
  local previous_head
  local reason

  current_head="\$(git rev-parse HEAD 2>/dev/null || true)"
  dirty_status="\$(git status --porcelain --untracked-files=all 2>/dev/null || true)"
  previous_head=""
  if [[ -f "\${build_state_path}" ]]; then
    previous_head="\$(<"\${build_state_path}")"
  fi

  if [[ ! -x "\${binary_path}" ]]; then
    reason="target binary is missing"
  elif [[ -n "\${dirty_status}" ]]; then
    reason="worktree has uncommitted changes"
  elif [[ "\${current_head}" != "\${previous_head}" ]]; then
    reason="HEAD changed from \${previous_head:-none} to \${current_head:-unknown}"
  else
    echo "Reusing existing build for \${current_head}"
    return 0
  fi

  echo "Building because \${reason}"
  if ! ${build_command}; then
    /usr/bin/osascript -e 'display notification "${build_failure_message}" with title "${app_name}"' || true
    exit 1
  fi

  if [[ -z "\${dirty_status}" && -n "\${current_head}" ]]; then
    printf '%s\\n' "\${current_head}" > "\${build_state_path}"
  fi
}

sign_binary_if_needed() {
  local current_identifier
  current_identifier="\$(/usr/bin/codesign -dv "\${binary_path}" 2>&1 | /usr/bin/awk -F= '/^Identifier=/ { print \$2 }')"

  if [[ "\${current_identifier}" != "\${binary_identifier}" ]]; then
    /usr/bin/codesign \\
      --force \\
      --options runtime \\
      --entitlements "\${entitlements}" \\
      --identifier "\${binary_identifier}" \\
      --sign - \\
      "\${binary_path}"
  fi
}

mkdir -p "\${log_dir}"

{
  printf '\\n[%s] Launching ${app_name} from %s\\n' "\$(date '+%Y-%m-%d %H:%M:%S')" "\${repo_dir}"
  cd "\${repo_dir}" || exit 1
  build_if_needed
  sign_binary_if_needed
  if [[ -n "${runtime_release_channel}" ]]; then
    exec env ZED_RELEASE_CHANNEL="${runtime_release_channel}" "\${binary_path}" "\$@"
  else
    exec "\${binary_path}" "\$@"
  fi
} >> "\${log_file}" 2>&1
EOF
  chmod +x "${launcher}"

  sips -z 16 16 "${source_icon}" --out "${iconset_dir}/icon_16x16.png" >/dev/null
  sips -z 32 32 "${source_icon}" --out "${iconset_dir}/icon_16x16@2x.png" >/dev/null
  sips -z 32 32 "${source_icon}" --out "${iconset_dir}/icon_32x32.png" >/dev/null
  sips -z 64 64 "${source_icon}" --out "${iconset_dir}/icon_32x32@2x.png" >/dev/null
  sips -z 128 128 "${source_icon}" --out "${iconset_dir}/icon_128x128.png" >/dev/null
  sips -z 256 256 "${source_icon}" --out "${iconset_dir}/icon_128x128@2x.png" >/dev/null
  sips -z 256 256 "${source_icon}" --out "${iconset_dir}/icon_256x256.png" >/dev/null
  sips -z 512 512 "${source_icon}" --out "${iconset_dir}/icon_256x256@2x.png" >/dev/null
  sips -z 512 512 "${source_icon}" --out "${iconset_dir}/icon_512x512.png" >/dev/null
  cp "${source_icon}" "${iconset_dir}/icon_512x512@2x.png"
  iconutil -c icns "${iconset_dir}" -o "${icon_file}"
  rm -rf "${iconset_dir}"

  /usr/bin/touch "${app_dir}"
  /usr/bin/codesign \
    --force \
    --deep \
    --options runtime \
    --entitlements "${entitlements}" \
    --identifier "${bundle_identifier}" \
    --sign - \
    "${app_dir}" >/dev/null
  /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "${app_dir}" >/dev/null 2>&1 || true

  echo "Installed ${app_dir}"
}

install_cli_command() {
  local command_path="${cli_bin_dir}/zed"

  mkdir -p "${cli_bin_dir}"

  cat > "${command_path}" <<EOF
#!/bin/zsh

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:\${PATH}"

repo_dir="${repo_dir}"
entitlements="${entitlements}"
log_dir="\${HOME}/Library/Logs/SlopZed"
log_file="\${log_dir}/zed-cli.log"
build_state_path="\${log_dir}/local.slopzed.launcher.nightly.cli.build-state"
zed_binary="\${repo_dir}/target/debug/zed"
cli_binary="\${repo_dir}/target/debug/cli"
zed_identifier="local.slopzed.launcher.nightly.zed"
cli_identifier="local.slopzed.launcher.nightly.cli"

build_if_needed() {
  local current_head
  local dirty_status
  local previous_head
  local reason

  current_head="\$(git rev-parse HEAD 2>/dev/null || true)"
  dirty_status="\$(git status --porcelain --untracked-files=all 2>/dev/null || true)"
  previous_head=""
  if [[ -f "\${build_state_path}" ]]; then
    previous_head="\$(<"\${build_state_path}")"
  fi

  if [[ ! -x "\${zed_binary}" || ! -x "\${cli_binary}" ]]; then
    reason="target binary is missing"
  elif [[ -n "\${dirty_status}" ]]; then
    reason="worktree has uncommitted changes"
  elif [[ "\${current_head}" != "\${previous_head}" ]]; then
    reason="HEAD changed from \${previous_head:-none} to \${current_head:-unknown}"
  else
    echo "Reusing existing build for \${current_head}"
    return 0
  fi

  echo "Building because \${reason}"
  cargo build --package zed --package cli

  if [[ -z "\${dirty_status}" && -n "\${current_head}" ]]; then
    printf '%s\\n' "\${current_head}" > "\${build_state_path}"
  fi
}

sign_binary_if_needed() {
  local binary_path="\$1"
  local binary_identifier="\$2"
  local current_identifier

  current_identifier="\$(/usr/bin/codesign -dv "\${binary_path}" 2>&1 | /usr/bin/awk -F= '/^Identifier=/ { print \$2 }')"

  if [[ "\${current_identifier}" != "\${binary_identifier}" ]]; then
    /usr/bin/codesign \\
      --force \\
      --options runtime \\
      --entitlements "\${entitlements}" \\
      --identifier "\${binary_identifier}" \\
      --sign - \\
      "\${binary_path}"
  fi
}

mkdir -p "\${log_dir}"

{
  cd "\${repo_dir}" || exit 1
  build_if_needed
  sign_binary_if_needed "\${zed_binary}" "\${zed_identifier}"
  sign_binary_if_needed "\${cli_binary}" "\${cli_identifier}"
} >> "\${log_file}" 2>&1

exec env ZED_RELEASE_CHANNEL="nightly" "\${cli_binary}" --zed "\${zed_binary}" "\$@"
EOF

  chmod +x "${command_path}"
  echo "Installed ${command_path}"
}

install_app \
  "SlopZed" \
  "local.slopzed.launcher" \
  "cargo build --release --package zed --package cli" \
  "target/release/zed" \
  "" \
  "Release build failed. See ~/Library/Logs/SlopZed/SlopZed.log"

install_app \
  "SlopZed (Nightly)" \
  "local.slopzed.launcher.nightly" \
  "cargo build --package zed --package cli" \
  "target/debug/zed" \
  "nightly" \
  "Dev build failed. See ~/Library/Logs/SlopZed/SlopZed (Nightly).log"

install_cli_command
